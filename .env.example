# LLM
# Get a NVIDIA API key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# Embeddings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16

# Reranker
# Downloaded automatically on first use from Hugging Face Hub.
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# Vector DB
CHROMA_DB_PATH=./chroma_db

# Chunking
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=30

# Retrieval
TOP_K_CANDIDATES=40
TOP_K_RESULTS=5
USE_HYDE=true

# SEC EDGAR
# SEC requires a real identifier in the format: Name email@example.com
EDGAR_USER_AGENT=FinLens your-email@example.com

# Storage
UPLOAD_DIR=./uploads

# Frontend
BACKEND_URL=http://localhost:8000
UPLOAD_TIMEOUT_SECONDS=900
